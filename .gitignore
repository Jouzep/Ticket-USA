# ────────────────────────────────────────────────────────────
# Python — anchored to /backend to avoid catching frontend/lib
# ────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Python venv/build dirs — anchored so they don't match frontend
/backend/build/
/backend/develop-eggs/
/backend/dist/
/backend/downloads/
/backend/eggs/
/backend/.eggs/
/backend/lib/
/backend/lib64/
/backend/parts/
/backend/sdist/
/backend/var/
/backend/wheels/

# Generic venv patterns (safe — name collision unlikely)
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ────────────────────────────────────────────────────────────
# Playwright
# ────────────────────────────────────────────────────────────
playwright-report/
test-results/
playwright/.cache/

# ────────────────────────────────────────────────────────────
# Node / Next.js
# ────────────────────────────────────────────────────────────
node_modules/
.next/
out/
*.local
.pnpm-store/
.vite/
.turbo/

# ────────────────────────────────────────────────────────────
# Env secrets
# ────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ────────────────────────────────────────────────────────────
# IDE / OS
# ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# ────────────────────────────────────────────────────────────
# Logs & coverage
# ────────────────────────────────────────────────────────────
*.log
logs/
coverage/
