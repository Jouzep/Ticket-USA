# ──────────────────────────────────────────────
# Backend (FastAPI)
# ──────────────────────────────────────────────

# App
APP_ENV=development
LOG_LEVEL=INFO

# CORS — origins allowed for SSE/API (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Scraper mode: "mock" | "real"
# mock = deterministic fake data (safe for dev/deploy/demo)
# real = Playwright against process.dmv.ny.gov
SCRAPER_MODE=mock

# Browser pool size (real mode only)
BROWSER_POOL_SIZE=3

# Scraping timeouts (seconds)
SCRAPER_PAGE_TIMEOUT=20
SCRAPER_NAVIGATION_TIMEOUT=30

# Job limits
MAX_TICKETS_PER_JOB=500
JOB_TTL_SECONDS=3600

# SSE
SSE_HEARTBEAT_INTERVAL=15

# Claude API (optional — leave empty to disable AI agent)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=1024

# ──────────────────────────────────────────────
# Frontend (Vite)
# ──────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
